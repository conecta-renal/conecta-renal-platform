# -----------------------------------------------------------------------------
# ATENÇÃO: este é um arquivo de EXEMPLO.
#
# NÃO preencha este arquivo com valores reais e NÃO faça commit dele com
# credenciais verdadeiras.
#
# Para uso local, copie este arquivo para "terraform.tfvars" (sem o
# ".example") e preencha com os valores reais. O arquivo "terraform.tfvars"
# já está listado no .gitignore e não deve ser versionado.
# -----------------------------------------------------------------------------

# ID da assinatura Azure.
# Como obter: `az account show --query id -o tsv`
subscription_id = "00000000-0000-0000-0000-000000000000"

# ID do tenant Microsoft Entra ID.
# Como obter: `az account show --query tenantId -o tsv`
tenant_id = "11111111-1111-1111-1111-111111111111"

# Client ID (App ID) do Service Principal usado pelo Terraform.
# Como obter: gerado ao criar o Service Principal com
# `az ad sp create-for-rbac --name "<nome>" --role Contributor --scopes /subscriptions/<subscription_id>`
client_id = "22222222-2222-2222-2222-222222222222"

# Client Secret do Service Principal usado pelo Terraform.
# Como obter: gerado no mesmo comando `az ad sp create-for-rbac` acima
# (o valor só é exibido uma vez no momento da criação).
client_secret = "SUBSTITUA_PELO_SECRET_REAL"

# Região Azure onde os recursos serão provisionados.
location = "brazilsouth"

# Nome do ambiente (dev, staging, prod).
environment = "dev"

# Nome do projeto, usado em nomenclatura de recursos e tags.
project_name = "conecta-renal"
